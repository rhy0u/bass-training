# ===========================================
# Friends Project - Environment Variables
# ===========================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://friends.local

# PostgreSQL
POSTGRES_USER=friends_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=friends_db
POSTGRES_PORT=5432

# Database URL (used by Prisma)
DATABASE_URL=postgresql://friends_user:change_me_in_production@localhost:5432/friends_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Nginx
VIRTUAL_HOST=friends.local
