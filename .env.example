# ===========================================
# Boilerplate Project - Environment Variables
# ===========================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://boilerplate.local

# PostgreSQL
POSTGRES_USER=boilerplate_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=boilerplate_db
POSTGRES_PORT=5432

# Database URL (used by Prisma)
DATABASE_URL=postgresql://boilerplate_user:change_me_in_production@localhost:5432/boilerplate_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Nginx
VIRTUAL_HOST=boilerplate.local
