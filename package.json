{
  "name": "boilerplate",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "init-project": "bash scripts/init.sh",
    "dev": "yarn workspace @boilerplate/web dev",
    "build": "yarn workspace @boilerplate/web build",
    "start": "yarn workspace @boilerplate/web start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test --log-order=grouped",
    "test:coverage": "turbo run test:coverage --log-order=grouped",
    "db:generate": "yarn workspace @boilerplate/database db:generate",
    "db:push": "yarn workspace @boilerplate/database db:push",
    "db:migrate": "yarn workspace @boilerplate/database db:migrate",
    "db:studio": "yarn workspace @boilerplate/database db:studio",
    "db:seed": "yarn workspace @boilerplate/database db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build",
    "storybook": "yarn workspace @boilerplate/ui storybook"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "turbo": "^2.4.0",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  }
}